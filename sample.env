# Notion object IDs referenced by the sample documentation.
#
# These point the sample's links and mentions at objects in a particular
# Notion workspace. They are NOT secret. The Notion integration token lives
# separately in the gitignored ``.env`` file.
#
# To target your own workspace, regenerate this file with:
#
#     uv run --all-extras python bootstrap-sample-env.py --parent-page-id parent_page_id
#
# These lines are plain ``KEY=value`` pairs so the file can be both sourced by
# a shell (``set -a; source sample.env``) and appended to ``$GITHUB_ENV``.
NOTION_SAMPLE_PAGE_ID=2579ce7b60a48071b51bfc2a206bac17
NOTION_SAMPLE_USER_ID=fc820d21-80ec-4d06-878c-f991bc8070d2
NOTION_SAMPLE_DATABASE_ID=27d9ce7b60a4804b9c5cfa002668952b
